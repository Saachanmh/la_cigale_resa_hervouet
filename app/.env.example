# Configuration Airtable pour le CRM Réservations
#
# IMPORTANT: Copiez ce fichier vers .env et remplacez les valeurs
#
# 1. AIRTABLE_API_KEY : Personal Access Token d'Airtable
#    - Créer sur : https://airtable.com/create/tokens
#    - Scopes requis : data.records:read, data.records:write
#    - Format : patXXXXXXXXXXXXXXXX.YYYYYYYYYYYYYYYY.ZZZZZZZZZZZ (≈60 caractères)
AIRTABLE_API_KEY=your_airtable_api_key_here

# 2. AIRTABLE_BASE_ID : ID de votre base (dans l'URL Airtable)
#    - Format : appXXXXXXXXXXXXXX (17 caractères)
#    - Exemple : si URL = https://airtable.com/appN81S2UqL2vxXVH/tblYYYYY
#    - Alors BASE_ID = appN81S2UqL2vxXVH
AIRTABLE_BASE_ID=your_airtable_base_id_here

# 3. AIRTABLE_TABLE_NAME : Nom exact de votre table
AIRTABLE_TABLE_NAME=Reservations

# Port optionnel pour le serveur BFF (défaut 3001)
PORT=3001

